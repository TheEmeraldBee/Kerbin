bind [up] [if [mode v] --cmds [ml -1 --extend] --else_cmds [ml -1]] --desc "Up"
bind [down] [if [mode v] --cmds [ml 1 --extend] --else_cmds [ml 1]] --desc "Down"
bind [left] [if [mode v] --cmds [mc -1 --extend] --else_cmds [mc -1]] --desc "Left"
bind [right] [if [mode v] --cmds [mc 1 --extend] --else_cmds [mc 1]] --desc "Right"

bind [k] [if [mode v] --cmds [ml -1 --extend] --else_cmds [ml -1]] --desc "Up"
bind [j] [if [mode v] --cmds [ml 1 --extend] --else_cmds [ml 1]] --desc "Down"
bind [h] [if [mode v] --cmds [mc -1 --extend] --else_cmds [mc -1]] --desc "Left"
bind [l] [if [mode v] --cmds [mc 1 --extend] --else_cmds [mc 1]] --desc "Right"
