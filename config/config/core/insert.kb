# Insert mode keybindings

bind [i] [pm i] --invalid [i] --desc "Insert Mode"
bind [enter] [ts_nl] --modes [i] --desc "Insert Newline"
bind [tab] [[a '    '] [gse] [cs]] --modes [i]
bind [%alphabet] [a %0] --modes [i] --desc "Insert character"
bind [%cap_alphabet] [a %0] --modes [i] --desc "Insert character"
bind [%numbers] [a %0] --modes [i] --desc "Insert character"
bind [%symbols] [a %0] --modes [i] --desc "Insert character"
bind [space] [a ' '] --modes [i] --desc "Insert character"
