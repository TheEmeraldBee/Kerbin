# Insert mode keybindings

bind [i] [pm i] --invalid [i] --desc "Insert Mode"

# Insertions
bind [enter] [a "\n"] --modes [i] --desc "Insert Newline"
bind [tab] [[a %tab_unit] [gse] [cs]] --modes [i]
bind [%insert] [if [mode v] --cmds [a %0 --extend] --else_cmds [a %0]] --modes [i] --desc "Insert character"
bind [space] [a ' '] --modes [i] --desc "Insert character"

# Deletions
bind [backspace] [[mc -1] [d]] --modes [i] --desc "Backspace"
