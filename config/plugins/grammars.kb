# Tree-sitter grammar definitions
# Each grammar is identified by its name (determines .so file and query paths).
# --langs lists the language names this grammar serves (from register_language).
# Grammars with empty --langs are injection-only and not directly opened as files.

# Kerbin Language
tree_sitter_define kerbin --langs [kerbin] --url https://github.com/EmeraldPandaTurtle/tree-sitter-kerbin.git

# Bash
tree_sitter_define bash --langs [bash] --url https://github.com/tree-sitter/tree-sitter-bash.git

# Go
tree_sitter_define go --langs [go] --url https://github.com/tree-sitter/tree-sitter-go.git

# Rust
tree_sitter_define rust --langs [rust rust_format_args_macro] --url https://github.com/tree-sitter/tree-sitter-rust.git
tree_sitter_define rust_format_args --langs [] --url https://github.com/nik-rev/tree-sitter-rust-format-args.git --build_name rust-format-args

# Python
tree_sitter_define python --langs [python] --url https://github.com/tree-sitter/tree-sitter-python.git

# Toml
tree_sitter_define toml --langs [toml] --url https://github.com/ikatyang/tree-sitter-toml.git

# Comment (injection-only)
tree_sitter_define comment --langs [] --url https://github.com/stsewd/tree-sitter-comment.git

# Markdown
tree_sitter_define markdown --langs [markdown markdown_rustdoc tutor] --url https://github.com/tree-sitter-grammars/tree-sitter-markdown.git --sub_dir tree-sitter-markdown
tree_sitter_define markdown_inline --langs [] --url https://github.com/tree-sitter-grammars/tree-sitter-markdown.git --sub_dir tree-sitter-markdown-inline --build_name markdown-inline

# Nushell
tree_sitter_define nu --langs [nu] --url https://github.com/nushell/tree-sitter-nu.git

# Html
tree_sitter_define html --langs [html] --url https://github.com/tree-sitter/tree-sitter-html.git

# JavaScript / JSX (same grammar handles both)
tree_sitter_define javascript --langs [javascript jsx] --url https://github.com/tree-sitter/tree-sitter-javascript.git

# TypeScript / TSX (separate grammars from the same repo)
tree_sitter_define typescript --langs [typescript] --url https://github.com/tree-sitter/tree-sitter-typescript.git --sub_dir typescript
tree_sitter_define tsx --langs [typescriptreact] --url https://github.com/tree-sitter/tree-sitter-typescript.git --sub_dir tsx

# CSS / SCSS
tree_sitter_define css --langs [css] --url https://github.com/tree-sitter/tree-sitter-css.git
tree_sitter_define scss --langs [scss] --url https://github.com/serenadeai/tree-sitter-scss.git

# C / C++
tree_sitter_define c --langs [c] --url https://github.com/tree-sitter/tree-sitter-c.git
tree_sitter_define cpp --langs [cpp] --url https://github.com/tree-sitter/tree-sitter-cpp.git

# JSON / YAML
tree_sitter_define json --langs [json] --url https://github.com/tree-sitter/tree-sitter-json.git
tree_sitter_define yaml --langs [yaml] --url https://github.com/ikatyang/tree-sitter-yaml.git

# Scheme
tree_sitter_define scheme --langs [scheme] --url https://github.com/6cdh/tree-sitter-scheme.git

# Lua
tree_sitter_define lua --langs [lua] --url https://github.com/tree-sitter-grammars/tree-sitter-lua.git

# Ruby
tree_sitter_define ruby --langs [ruby] --url https://github.com/tree-sitter/tree-sitter-ruby.git

# Java
tree_sitter_define java --langs [java] --url https://github.com/tree-sitter/tree-sitter-java.git

# C#
tree_sitter_define c_sharp --langs [c_sharp] --url https://github.com/tree-sitter/tree-sitter-c-sharp.git

# PHP
tree_sitter_define php --langs [php] --url https://github.com/tree-sitter/tree-sitter-php.git --sub_dir php

# Zig
tree_sitter_define zig --langs [zig] --url https://github.com/tree-sitter-grammars/tree-sitter-zig.git

# Elixir
tree_sitter_define elixir --langs [elixir] --url https://github.com/elixir-lang/tree-sitter-elixir.git

# Haskell
tree_sitter_define haskell --langs [haskell] --url https://github.com/tree-sitter/tree-sitter-haskell.git

# Kotlin
tree_sitter_define kotlin --langs [kotlin] --url https://github.com/fwcd/tree-sitter-kotlin.git

# Justfile (grammar name is "just", language name is "justfile")
tree_sitter_define just --langs [justfile] --url https://github.com/casey/tree-sitter-just.git

# Makefile (grammar name is "make", serves both "make" and "makefile" languages)
tree_sitter_define make --langs [make makefile] --url https://github.com/alemuller/tree-sitter-make.git

# Dockerfile
tree_sitter_define dockerfile --langs [dockerfile] --url https://github.com/camdencheek/tree-sitter-dockerfile.git

# Git
tree_sitter_define git_commit --langs [git_commit] --url https://github.com/the-mikedavis/tree-sitter-git-commit.git
tree_sitter_define git_config --langs [git_config] --url https://github.com/the-mikedavis/tree-sitter-git-config.git

# Regex (injection-only)
tree_sitter_define regex --langs [] --url https://github.com/tree-sitter/tree-sitter-regex.git
